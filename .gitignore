# Python
.venv/
__pycache__/
*.pyc

# PyInstaller build output
build/
dist/
*.spec
*.zip

# Local user output (don't ship a user's renders to the repo)
ribbonoutput/*
!ribbonoutput/.gitkeep

# Runtime-generated local config (created on first run, per-user)
settings.json
Engine Profiles/*
!Engine Profiles/.gitkeep

# Per-user saved presets (don't ship one user's loadouts to the repo)
loadouts/*
!loadouts/.gitkeep

# Local-only throwaway faction for live testing — never ship to prod
assets/TESTFACTION/
factions/TESTFACTION.json
